# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------

# A strong random string used for bearer token auth.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Path to the SQLite database file inside the backend container.
# The directory must match the volume mount defined in compose.yaml.
DATABASE_PATH=/app/data/carepatterns.db

# Origin the backend CORS middleware permits.
# Development: http://localhost:3000
# Production: update to the hostname/IP used to access the frontend.
ALLOWED_ORIGIN=http://localhost:3000

# IANA timezone name used by the reminder service when evaluating schedule windows.
# "Once daily at 9am" means 9am in this timezone.
# All datetimes are stored in the database as UTC.
TIMEZONE=America/Los_Angeles

# How often (in seconds) the backend considers a schedule overdue.
# (Informational — the backend uses this via the reminder_service logic.)
REMINDER_POLL_INTERVAL_SECONDS=60

# ---------------------------------------------------------------------------
# Frontend (VITE_ prefix — baked into the JS bundle at build time)
# ---------------------------------------------------------------------------

# WARNING: VITE_ variables are embedded in the compiled JS bundle.
# Only deploy on a private, trusted network.

# Must be the same value as SECRET_KEY above.
# Used by the frontend to authenticate every API request.
VITE_API_TOKEN=your-secret-key-here

# How often (in seconds) the frontend polls for outstanding reminders.
# Defaults to 60 if not set.
VITE_REMINDER_POLL_INTERVAL=60
